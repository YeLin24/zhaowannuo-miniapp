/* 自定义TabBar样式 */
/* 从示例图提取：背景#FFFFFF，上边框0.5px #eee，高度83px (含安全区34px) */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(166rpx + env(safe-area-inset-bottom));
  padding: 16rpx 0 34rpx;
  background-color: #FFFFFF;
  border-top: 1rpx solid #EEEEEE;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  z-index: 100;
}

.tab-bar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  position: relative;
}

.tab-bar__text {
  font-size: 20rpx;
  color: #999999;
  font-weight: 400;
  line-height: 1;
}

.tab-bar__item--active .tab-bar__text {
  color: #000000;
  font-weight: 600;
}
