/* 对应示例图1：首页样式 */

.page {
  background-color: var(--color-bg);
  min-height: 100vh;
  position: relative;
}

/* ===== NavBar ===== */
.navbar {
  position: sticky;
  top: 0;
  left: 0;
  right: 0;
  background-color: var(--color-bg);
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 var(--spacing-lg) var(--spacing-sm);
  z-index: 50;
  box-sizing: border-box;
}

.navbar__left {
  display: flex;
  align-items: center;
}

/* Home图标：用纯CSS绘制 */
.navbar__home-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  position: relative;
}

.home-icon-roof {
  width: 0;
  height: 0;
  border-left: 22rpx solid transparent;
  border-right: 22rpx solid transparent;
  border-bottom: 18rpx solid var(--color-primary);
  position: absolute;
  top: 0;
}

.home-icon-body {
  width: 32rpx;
  height: 22rpx;
  background-color: var(--color-primary);
  position: absolute;
  bottom: 0;
}

.navbar__right {
  display: flex;
  align-items: center;
}

/* 胶囊按钮 */
/* 从示例图提取：宽174rpx，高64rpx，边框#E5E5E5，圆角32rpx */
.capsule-btn {
  width: 174rpx;
  height: 64rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
}

.capsule-dots {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
}

.capsule-divider {
  width: 1rpx;
  height: 32rpx;
  background-color: var(--color-border);
}

.capsule-circle {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-primary);
}

/* ===== 品牌Logo ===== */
/* 从示例图提取：左对齐，font-weight:700，大字号 */
.brand-logo {
  padding: 8px 16px 4px;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.brand-logo__text {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 2rpx;
  font-family: "Arial Black", "PingFang SC", sans-serif;
}

.brand-logo__reg {
  font-size: 20rpx;
  color: var(--color-primary);
  margin-top: 8rpx;
  font-weight: 400;
}

/* ===== 次级导航 ===== */
/* 从示例图提取：#333333，两端对齐 */
.sub-nav {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 8px 16px 6px;
}

.sub-nav__left,
.sub-nav__right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.sub-nav__text {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  font-weight: 400;
}

.sub-nav__plus,
.sub-nav__arrow {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}

/* ===== 黑色Banner ===== */
/* 从示例图提取：纯黑背景#000000，文字单行居中 */
.banner-black {
  width: 100%;
  background-color: var(--color-dark-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10px 16px;
}

.banner-black__text {
  font-size: var(--font-size-base);
  color: var(--color-bg);
  font-weight: 400;
  text-align: center;
  letter-spacing: 1rpx;
}

/* ===== 模特图区域 ===== */
.model-section {
  width: 100%;
  position: relative;
}

.model-img {
  width: 100%;
  display: block;
}

.model-section:first-of-type .model-img {
  height: 520rpx;
}

.model-section:last-of-type .model-img {
  height: 480rpx;
}

/* 10px gap between images */
.model-section:first-of-type {
  margin-bottom: 20rpx;
}

.model-label {
  position: absolute;
  bottom: 16px;
  right: 16px;
  padding: 0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.model-label__text {
  font-size: var(--font-size-sm);
  color: rgba(255,255,255,0.9);
  letter-spacing: 1rpx;
  text-shadow: 0 1px 4px rgba(0,0,0,0.5);
}

/* ===== 悬浮礼物按钮 ===== */
/* 从示例图提取：橙色渐变，直径96rpx，右下角定位 */
.float-gift {
  position: fixed;
  right: var(--spacing-lg);
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.4);
}

.float-gift__icon {
  font-size: 44rpx;
}

/* ===== 加载/错误状态 ===== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-bg-secondary);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  gap: var(--spacing-lg);
}

.error-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

.retry-btn {
  padding: var(--spacing-sm) 48rpx;
  background-color: var(--color-primary);
  color: var(--color-bg);
  border-radius: 40rpx;
  font-size: var(--font-size-base);
}
