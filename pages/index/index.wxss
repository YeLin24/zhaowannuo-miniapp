/* 对应示例图1：首页样式 */

.page {
  background-color: #FFFFFF;
  min-height: 100vh;
  position: relative;
}

/* ===== NavBar ===== */
.navbar {
  position: sticky;
  top: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF; /* 从示例图提取：#FFFFFF */
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 32rpx 16rpx;
  z-index: 50;
  box-sizing: border-box;
}

.navbar__left {
  display: flex;
  align-items: center;
}

/* Home图标：用纯CSS绘制 */
.navbar__home-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  position: relative;
}

.home-icon-roof {
  width: 0;
  height: 0;
  border-left: 22rpx solid transparent;
  border-right: 22rpx solid transparent;
  border-bottom: 18rpx solid #000000;
  position: absolute;
  top: 0;
}

.home-icon-body {
  width: 32rpx;
  height: 22rpx;
  background-color: #000000;
  position: absolute;
  bottom: 0;
}

.navbar__right {
  display: flex;
  align-items: center;
}

/* 胶囊按钮 */
/* 从示例图提取：宽174rpx，高64rpx，边框#E5E5E5，圆角32rpx */
.capsule-btn {
  width: 174rpx;
  height: 64rpx;
  border: 1rpx solid #E5E5E5;
  border-radius: 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
}

.capsule-dots {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: #000000;
}

.capsule-divider {
  width: 1rpx;
  height: 32rpx;
  background-color: #E5E5E5;
}

.capsule-circle {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #000000;
}

/* ===== 品牌Logo ===== */
/* 从示例图提取：左对齐，font-weight:700，大字号 */
.brand-logo {
  padding: 24rpx 32rpx 16rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.brand-logo__text {
  font-size: 44rpx; /* 从示例图提取：比规格稍大，对应图中实际尺寸 */
  font-weight: 700;
  color: #000000;
  letter-spacing: 2rpx;
  font-family: "Arial Black", "PingFang SC", sans-serif;
}

.brand-logo__reg {
  font-size: 20rpx;
  color: #000000;
  margin-top: 8rpx;
  font-weight: 400;
}

/* ===== 次级导航 ===== */
/* 从示例图提取：#333333，两端对齐 */
.sub-nav {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 32rpx 20rpx;
}

.sub-nav__left,
.sub-nav__right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.sub-nav__text {
  font-size: 26rpx;
  color: #333333; /* 从示例图提取：#333333 */
  font-weight: 400;
}

.sub-nav__plus,
.sub-nav__arrow {
  font-size: 24rpx;
  color: #333333;
}

/* ===== 黑色Banner ===== */
/* 从示例图提取：纯黑背景#000000，文字单行居中，高约400rpx */
.banner-black {
  width: 100%;
  height: 400rpx;
  background-color: #000000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
}

.banner-black__text {
  font-size: 28rpx; /* 从示例图提取：单行文字，适中大小 */
  color: #FFFFFF;
  font-weight: 400;
  text-align: center;
  letter-spacing: 1rpx;
}

/* ===== 模特图区域 ===== */
.model-section {
  width: 100%;
  position: relative;
}

.model-img {
  width: 100%;
}

.model-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 0;
  background: linear-gradient(to top, rgba(0,0,0,0.4), transparent);
  display: flex;
  align-items: center;
  justify-content: center;
}

.model-label__text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  letter-spacing: 2rpx;
}

/* ===== 悬浮礼物按钮 ===== */
/* 从示例图提取：橙色渐变，直径96rpx，右下角定位 */
.float-gift {
  position: fixed;
  right: 32rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35, #FF8C42); /* 从示例图提取：橙色渐变 */
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.4);
}

.float-gift__icon {
  font-size: 44rpx;
}

/* ===== 加载/错误状态 ===== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #F0F0F0;
  border-top-color: #000000;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  gap: 32rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999999;
}

.retry-btn {
  padding: 16rpx 48rpx;
  background-color: #000000;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 26rpx;
}
