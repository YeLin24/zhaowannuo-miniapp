<!-- 对应示例图1：首页 -->
<!-- 关键：Logo左对齐，Banner单行文字居中，模特图全宽 -->

<view class="page" style="padding-bottom: calc(100rpx + {{safeBottom}}px)">

  <!-- 顶部自定义NavBar -->
  <view class="navbar" style="padding-top: {{statusBarHeight}}px; height: calc({{statusBarHeight}}px + 88rpx)">
    <!-- 左：Home图标 -->
    <view class="navbar__left">
      <view class="navbar__home-icon">
        <view class="home-icon-roof"></view>
        <view class="home-icon-body"></view>
      </view>
    </view>
    <!-- 右：胶囊按钮（...+圆圈） -->
    <view class="navbar__right">
      <view class="capsule-btn">
        <view class="capsule-dots">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
        <view class="capsule-divider"></view>
        <view class="capsule-circle"></view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{hasError}}" class="error-wrap">
    <text class="error-text">加载失败，点击重试</text>
    <view class="retry-btn" bindtap="loadData">重试</view>
  </view>

  <!-- 正常内容 -->
  <block wx:else>
    <!-- 品牌Logo：左对齐 -->
    <!-- 占位符：示例图1顶部Logo区域 -->
    <view class="brand-logo">
      <text class="brand-logo__text">ZHAOWANNUO</text>
      <text class="brand-logo__reg">®</text>
    </view>

    <!-- 次级导航：探索全部 | 2026 -->
    <view class="sub-nav">
      <view class="sub-nav__left">
        <text class="sub-nav__text">探索全部</text>
        <text class="sub-nav__plus">⊕</text>
      </view>
      <view class="sub-nav__right">
        <text class="sub-nav__text">2026</text>
        <text class="sub-nav__arrow">∨</text>
      </view>
    </view>

    <!-- 黑色破价专区Banner -->
    <view class="banner-black" bindtap="goSpecial">
      <text class="banner-black__text">破价专区 · Special Offer  点击进入 ></text>
    </view>

    <!-- 模特图区域（全宽） -->
    <!-- 占位符：请替换为示例图1的第一张模特图 -->
    <view class="model-section">
      <view class="model-img img-placeholder" style="aspect-ratio: 1316/1100">
        <text>【请替换】示例图1 - 第一张模特图（戴帽子牛仔外套）</text>
      </view>
      <view class="model-label">
        <text class="model-label__text">ZHAOWANNUO | 所有产品</text>
      </view>
    </view>

    <!-- 第二张内容图 -->
    <!-- 占位符：请替换为示例图1的第二张模特图 -->
    <view class="model-section">
      <view class="model-img img-placeholder" style="aspect-ratio: 1316/900">
        <text>【请替换】示例图1 - 第二张模特图（沙发坐姿黑色上衣）</text>
      </view>
    </view>

  </block>

  <!-- 悬浮礼物按钮（橙色渐变） -->
  <view class="float-gift" bindtap="onGiftTap">
    <text class="float-gift__icon">🎁</text>
  </view>

</view>
