<!-- 对应示例图4：上新页（新品） -->
<!-- 关键："直播间的小黄车"折叠标题+下划线，双列商品网格，黑色圆形购物车按钮 -->

<view class="page" style="padding-bottom: calc(100rpx + {{safeBottom}}px)">

  <!-- NavBar：Home图标左，"新品"标题（左对齐），胶囊右 -->
  <view class="navbar" style="padding-top: {{statusBarHeight}}px; height: calc({{statusBarHeight}}px + 88rpx)">
    <view class="navbar__left">
      <view class="navbar__home-icon">
        <view class="home-icon-roof"></view>
        <view class="home-icon-body"></view>
      </view>
      <text class="navbar__title">新品</text>
    </view>
    <view class="navbar__right">
      <view class="capsule-btn">
        <view class="capsule-circle"></view>
        <view class="capsule-divider"></view>
        <view class="capsule-dots">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
  </view>

  <view wx:elif="{{hasError}}" class="error-wrap">
    <text class="error-text">加载失败</text>
    <view class="retry-btn" bindtap="loadData">重试</view>
  </view>

  <block wx:else>
    <!-- 折叠标题区 -->
    <!-- 从图4提取：大粗体左对齐，下方有短横线装饰，右侧∨箭头 -->
    <view class="section-header" bindtap="toggleSection">
      <view class="section-header__left">
        <text class="section-header__title">直播间的小黄车</text>
        <view class="section-header__underline"></view>
      </view>
      <text class="section-header__arrow {{sectionExpanded ? 'arrow-up' : ''}}">∨</text>
    </view>

    <!-- 产品分类Banner -->
    <!-- 占位符：请替换为示例图4的产品分类banner -->
    <view class="banner-category">
      <view class="banner-category__img img-placeholder" style="aspect-ratio: 1316/500">
        <text>【请替换】示例图4 - 产品分类banner（室内场景）</text>
      </view>
      <view class="banner-category__overlay">
        <text class="banner-category__sub">Central Product Classification</text>
        <text class="banner-category__title">产 品 分 类</text>
        <view class="banner-category__btn">
          <text class="banner-category__btn-text">点击进入</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{productList.length === 0}}" class="empty-wrap">
      <text class="empty-text">暂无新品</text>
    </view>

    <!-- 双列商品网格 -->
    <!-- 从图4提取：gap:20rpx，padding:20rpx，白色卡片圆角12rpx -->
    <view wx:else class="product-grid">
      <view
        class="product-card"
        wx:for="{{productList}}"
        wx:key="id"
        bindtap="goDetail"
        data-id="{{item.id}}"
      >
        <!-- 图片区 -->
        <view class="product-card__img-wrap">
          <!-- 占位符：请替换为示例图4商品图 -->
          <view class="product-card__img img-placeholder">
            <text>【请替换】示例图4 - 商品图{{index+1}}</text>
          </view>
        </view>

        <!-- 品牌名（在图片下方） -->
        <view class="product-card__brand">
          <text class="product-card__brand-text">ZHAOWANNUO</text>
        </view>

        <!-- 商品名 -->
        <text class="product-card__name">{{item.name}}</text>

        <!-- 标签组 -->
        <view class="product-card__tags">
          <text
            class="tag"
            wx:for="{{item.tags}}"
            wx:key="*this"
            wx:for-item="tag"
          >{{tag}}</text>
        </view>

        <!-- 销售数据 -->
        <text class="product-card__sales">已售{{item.sales}}件 | 仅剩{{item.stock}}件</text>

        <!-- 价格行 + 购物车按钮 -->
        <view class="product-card__price-row">
          <text class="product-card__price">¥{{item.price}}</text>
          <!-- 黑色圆形购物车按钮（从图4提取） -->
          <view class="cart-btn" catchtap="onAddCart" data-id="{{item.id}}">
            <text class="cart-btn__icon">🛒</text>
          </view>
        </view>
      </view>
    </view>

  </block>

</view>
