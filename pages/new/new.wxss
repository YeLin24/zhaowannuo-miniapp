/* 对应示例图4：上新页样式 */

.page {
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* ===== NavBar ===== */
.navbar {
  background-color: #FFFFFF;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 32rpx 16rpx;
  box-sizing: border-box;
}

.navbar__left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.navbar__home-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.home-icon-roof {
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-bottom: 16rpx solid #000000;
  position: absolute;
  top: 0;
  left: 0;
}

.home-icon-body {
  width: 28rpx;
  height: 20rpx;
  background-color: #000000;
  position: absolute;
  bottom: 0;
  left: 6rpx;
}

/* "新品"标题：左对齐（从图4提取） */
.navbar__title {
  font-size: 32rpx;
  color: #000000;
  font-weight: 600;
}

.navbar__right { display: flex; align-items: center; }

.capsule-btn {
  width: 174rpx;
  height: 64rpx;
  border: 1rpx solid #E5E5E5;
  border-radius: 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
}

.capsule-dots { display: flex; flex-direction: row; align-items: center; gap: 6rpx; }
.dot { width: 8rpx; height: 8rpx; border-radius: 50%; background-color: #000000; }
.capsule-divider { width: 1rpx; height: 32rpx; background-color: #E5E5E5; }
.capsule-circle { width: 36rpx; height: 36rpx; border-radius: 50%; border: 2rpx solid #000000; }

/* ===== 折叠标题区 ===== */
/* 从图4提取：白色背景，粗体左对齐，短横线装饰，∨箭头右侧 */
.section-header {
  background-color: #FFFFFF;
  padding: 32rpx 32rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 2rpx;
}

.section-header__left {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
}

/* "直播间的小黄车"标题 */
/* 从图4提取：font-size约40rpx，font-weight:600 */
.section-header__title {
  font-size: 40rpx;
  color: #000000;
  font-weight: 600;
}

/* 标题下方短横线装饰（从图4提取） */
.section-header__underline {
  width: 48rpx;
  height: 4rpx;
  background-color: #000000;
  border-radius: 2rpx;
}

.section-header__arrow {
  font-size: 32rpx;
  color: #333333;
  margin-top: 8rpx;
  transition: transform 0.2s;
}

.arrow-up {
  transform: rotate(180deg);
}

/* ===== 产品分类Banner ===== */
.banner-category {
  width: 100%;
  position: relative;
  margin: 0 0 20rpx;
}

.banner-category__img {
  width: 100%;
}

.banner-category__overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.30);
  gap: 10rpx;
}

/* "Central Product Classification" 小字 */
.banner-category__sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  letter-spacing: 1rpx;
}

/* "产品分类"大字带字间距 */
/* 从图4提取：字间距明显，白色，大号 */
.banner-category__title {
  font-size: 44rpx;
  color: #FFFFFF;
  font-weight: 500;
  letter-spacing: 12rpx; /* 从图4提取：字间距大 */
}

.banner-category__btn {
  margin-top: 8rpx;
  background-color: #000000;
  padding: 10rpx 36rpx;
  border-radius: 40rpx;
}

.banner-category__btn-text {
  font-size: 22rpx;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

/* ===== 双列商品网格 ===== */
/* 从图4提取：padding:20rpx，gap:20rpx，白色卡片圆角12rpx */
.product-grid {
  padding: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

/* 商品卡片 */
.product-card {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding-bottom: 20rpx;
}

/* 图片区（正方形，aspect-ratio:1） */
.product-card__img-wrap {
  width: 100%;
  position: relative;
}

.product-card__img {
  width: 100%;
  aspect-ratio: 1;
  font-size: 18rpx;
  text-align: center;
  padding: 12rpx;
}

/* 图片底部品牌名（从图4提取：白色背景区域底部，灰色小字） */
.product-card__brand-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8rpx 0;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-card__brand-text {
  font-size: 18rpx;
  color: #BBBBBB;
  letter-spacing: 2rpx;
}

/* 商品名（两行截断） */
/* 从图4提取：26rpx，#000000 */
.product-card__name {
  font-size: 24rpx;
  color: #000000;
  padding: 16rpx 16rpx 8rpx;
  line-height: 1.4;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 标签组 */
.product-card__tags {
  padding: 0 16rpx 8rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 6rpx;
}

/* 标签（更小尺寸，从图4提取：18rpx） */
.tag {
  font-size: 18rpx;
  color: #666666;
  border: 1rpx solid #CCCCCC;
  border-radius: 4rpx;
  padding: 3rpx 10rpx;
  line-height: 1.4;
}

/* 销售数据 */
/* 从图4提取：22rpx，#999999 */
.product-card__sales {
  font-size: 22rpx;
  color: #999999;
  padding: 0 16rpx 12rpx;
}

/* 价格行 */
.product-card__price-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 16rpx;
  margin-top: auto;
}

/* 价格 */
/* 从图4提取：30rpx，font-weight:600 */
.product-card__price {
  font-size: 30rpx;
  color: #000000;
  font-weight: 600;
}

/* 黑色圆形购物车按钮 */
/* 从图4提取：直径56rpx，黑色背景，白色购物车图标 */
.cart-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #000000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-btn__icon {
  font-size: 28rpx;
  filter: brightness(10); /* 让emoji变白 */
}

/* ===== 空状态 ===== */
.empty-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
}

.empty-text { font-size: 28rpx; color: #999999; }

/* ===== 加载/错误状态 ===== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #F0F0F0;
  border-top-color: #000000;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  gap: 32rpx;
}

.error-text { font-size: 28rpx; color: #999999; }
.retry-btn {
  padding: 16rpx 48rpx;
  background-color: #000000;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 26rpx;
}
