/* 对应示例图6：分类页样式 */

.page {
  background-color: var(--color-bg-secondary);
  min-height: 100vh;
  position: relative;
}

/* ===== NavBar ===== */
.navbar {
  background-color: var(--color-bg);
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 var(--spacing-lg) var(--spacing-sm);
  box-sizing: border-box;
}

.navbar__left { display: flex; align-items: center; }

.navbar__home-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.home-icon-roof {
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-bottom: 16rpx solid var(--color-primary);
  position: absolute;
  top: 0;
  left: 0;
}

.home-icon-body {
  width: 28rpx;
  height: 20rpx;
  background-color: var(--color-primary);
  position: absolute;
  bottom: 0;
  left: 6rpx;
}

.navbar__right { display: flex; align-items: center; }

.capsule-btn {
  width: 174rpx;
  height: 64rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
}

.capsule-dots { display: flex; flex-direction: row; align-items: center; gap: 6rpx; }
.dot { width: 8rpx; height: 8rpx; border-radius: 50%; background-color: var(--color-primary); }
.capsule-divider { width: 1rpx; height: 32rpx; background-color: var(--color-border); }
.capsule-circle { width: 36rpx; height: 36rpx; border-radius: 50%; border: 2rpx solid var(--color-primary); }

/* ===== 居中Logo区 ===== */
/* 从图6提取：ZHAOWANNUO® 居中，下方 "官方旗舰店" 小字 */
.brand-header {
  background-color: var(--color-bg);
  padding: var(--spacing-md) var(--spacing-lg) 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.brand-logo-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.brand-logo__text {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 2rpx;
  font-family: "Arial Black", "PingFang SC", sans-serif;
}

.brand-logo__reg {
  font-size: 20rpx;
  color: var(--color-primary);
  margin-top: 8rpx;
  font-weight: 400;
}

/* "官方旗舰店"（从图6提取：小字，灰色） */
.brand-logo__sub {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  letter-spacing: 2rpx;
}

/* ===== 搜索框 ===== */
/* 从图6提取：圆角边框，搜索图标，全宽，白色背景 */
.search-bar {
  margin: 20rpx 24rpx;
  height: 80rpx;
  background-color: var(--color-bg);
  border-radius: 40rpx;
  border: 1rpx solid var(--color-bg-secondary);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.search-bar__icon {
  font-size: var(--font-size-lg);
}

.search-bar__placeholder {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

/* ===== 横向Tab标签 ===== */
/* 从图6提取：小程序专属（粗体黑色+下划线），其他灰色 */
.tab-bar-scroll {
  background-color: var(--color-bg);
  white-space: nowrap;
}

.tab-list {
  display: flex;
  flex-direction: row;
  padding: 0 24rpx;
  gap: 40rpx;
}

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  position: relative;
  white-space: nowrap;
}

.tab-item__text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  font-weight: 400;
}

.tab-item--active .tab-item__text {
  color: var(--color-primary);
  font-weight: 600;
}

/* 选中项下划线 */
/* 从图6提取：短横线，黑色，居中 */
.tab-item__underline {
  position: absolute;
  bottom: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: var(--color-primary);
  border-radius: 2rpx;
}

/* ===== Banner ===== */
.banner-category {
  width: 100%;
  position: relative;
  margin: 0 16px 16px;
}

.banner-img {
  width: 100%;
}

.banner-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.25);
  gap: 10rpx;
}

.banner-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  letter-spacing: 2rpx;
}

.banner-title {
  font-size: var(--font-size-xl);
  color: var(--color-bg);
  font-weight: 600;
  letter-spacing: 4rpx;
}

.banner-btn {
  background-color: var(--color-primary);
  padding: 10rpx 36rpx;
  border-radius: 40rpx;
  margin-top: 8rpx;
}

.banner-btn-text {
  font-size: 22rpx;
  color: var(--color-bg);
  letter-spacing: 2rpx;
}

/* ===== 双列商品网格（同上新页） ===== */
.product-grid {
  padding: 8px 12px 100px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.product-card {
  background-color: var(--color-bg);
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  border: 1rpx solid #f0f0f0;
}

.product-card__img-wrap {
  width: 100%;
}

.product-card__img {
  width: 100%;
  height: 320rpx;
  font-size: 18rpx;
  text-align: center;
  display: block;
}

/* 品牌名（在图片下方居中） */
.product-card__brand {
  padding: 12rpx 0 8rpx;
  background-color: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-card__brand-text {
  font-size: 20rpx;
  color: #999999;
  letter-spacing: 2rpx;
}

.product-card__name {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  padding: var(--spacing-sm) var(--spacing-sm) 8rpx;
  line-height: 1.4;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-card__tags {
  padding: 0 var(--spacing-sm) 8rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 6rpx;
}

.tag {
  font-size: 18rpx;
  color: var(--color-primary);
  border: 1rpx solid var(--color-tag-border);
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
}

.product-card__sales {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  padding: 0 var(--spacing-sm) 12rpx;
}

.product-card__price-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--spacing-sm);
}

.product-card__price {
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.cart-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-btn__icon {
  font-size: 28rpx;
}

/* ===== 空状态 ===== */
.empty-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
}

.empty-text { font-size: var(--font-size-base); color: var(--color-text-secondary); }

/* ===== 加载/错误状态 ===== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-bg-secondary);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  gap: var(--spacing-lg);
}

.error-text { font-size: var(--font-size-base); color: var(--color-text-secondary); }
.retry-btn {
  padding: var(--spacing-sm) 48rpx;
  background-color: var(--color-primary);
  color: var(--color-bg);
  border-radius: 40rpx;
  font-size: var(--font-size-base);
}

/* ===== 悬浮礼物按钮 ===== */
.float-gift {
  position: fixed;
  right: var(--spacing-lg);
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.4);
}

.float-gift__icon {
  font-size: 44rpx;
}
