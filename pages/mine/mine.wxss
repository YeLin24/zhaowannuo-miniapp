/* 对应示例图5：会员中心样式 */

.page {
  background-color: var(--color-bg-secondary);
  min-height: 100vh;
}

/* ===== NavBar（标题居中，从图5提取） ===== */
.navbar {
  background-color: var(--color-bg);
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 var(--spacing-lg) var(--spacing-sm);
  box-sizing: border-box;
  position: relative;
}

.navbar__left { width: 44rpx; }

.navbar__home-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.home-icon-roof {
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-bottom: 16rpx solid var(--color-primary);
  position: absolute;
  top: 0;
  left: 0;
}

.home-icon-body {
  width: 28rpx;
  height: 20rpx;
  background-color: var(--color-primary);
  position: absolute;
  bottom: 0;
  left: 6rpx;
}

/* "会员中心"标题：绝对居中 */
.navbar__title {
  position: absolute;
  left: 50%;
  bottom: 20rpx;
  transform: translateX(-50%);
  font-size: var(--font-size-lg);
  color: var(--color-primary);
  font-weight: 600;
}

.navbar__right { display: flex; align-items: center; }

.capsule-btn {
  width: 174rpx;
  height: 64rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
}

.capsule-dots { display: flex; flex-direction: row; align-items: center; gap: 6rpx; }
.dot { width: 8rpx; height: 8rpx; border-radius: 50%; background-color: var(--color-primary); }
.capsule-divider { width: 1rpx; height: 32rpx; background-color: var(--color-border); }
.capsule-circle { width: 36rpx; height: 36rpx; border-radius: 50%; border: 2rpx solid var(--color-primary); }

/* ===== 用户信息区 ===== */
.user-info {
  background-color: var(--color-bg);
  padding: 40rpx var(--spacing-lg);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.user-info__left {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

/* 用户ID行 */
.user-id-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

/* 用户ID "21" */
/* 从图5提取：36rpx，font-weight:600 */
.user-id {
  font-size: 48rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.user-id-arrow {
  font-size: 36rpx;
  color: var(--color-text-primary);
  font-weight: 300;
}

/* 会员badge */
/* 从图5提取：米色背景#F5F0E8，棕色文字#8B7355，圆角4rpx */
.member-badge {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  background-color: var(--color-vip-bg);
  border-radius: var(--radius-sm);
  padding: 6rpx 16rpx;
  align-self: flex-start;
}

.member-badge__icon {
  font-size: 20rpx;
  color: var(--color-vip-text);
  font-weight: 600;
}

.member-badge__text {
  font-size: 20rpx;
  color: var(--color-vip-text);
}

/* 头像圆形 */
/* 从图5提取：直径120rpx，圆形 */
.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  font-size: 16rpx;
  text-align: center;
  padding: 8rpx;
  border-radius: 50% !important;
  overflow: hidden;
}

/* ===== 购物须知卡片 ===== */
/* 从图5提取：浅灰圆角背景，内边距充足 */
.notice-card {
  background-color: #F8F6F2;
  border-radius: var(--radius-md);
  margin: 0 24rpx 20rpx;
  padding: 40rpx var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

/* "SHOPPING NOTICE" */
/* 从图5提取：大字，letter-spacing，#000000 */
.notice-card__title {
  font-size: var(--font-size-lg);
  color: var(--color-primary);
  font-weight: 600;
  letter-spacing: 4rpx;
  text-align: center;
}

/* "购物须知" 黑色badge */
.notice-card__subtitle-wrap {
  background-color: var(--color-primary);
  border-radius: var(--radius-sm);
  padding: 10rpx 28rpx;
}

.notice-card__subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-bg);
  letter-spacing: 4rpx;
}

/* 三栏须知 */
.notice-items {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  margin-top: 8rpx;
}

.notice-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.notice-item__icon {
  font-size: 36rpx;
}

.notice-item__text {
  font-size: 20rpx;
  color: var(--color-text-primary);
  text-align: center;
  line-height: 1.4;
}

/* ===== 功能菜单卡片 ===== */
/* 从图5提取：白色圆角卡片 */
.menu-card {
  background-color: var(--color-bg);
  border-radius: var(--radius-md);
  margin: 0 24rpx 20rpx;
  overflow: hidden;
}

/* 4图标单行排列（从图5提取：不是2×2，是水平一行） */
.menu-grid {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 40rpx 0;
}

.menu-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
}

/* 图标（从图5提取：outline风格，36rpx） */
.menu-item__icon {
  font-size: 48rpx;
  line-height: 1;
}

/* 菜单文字（从图5提取：24rpx，#333333） */
.menu-item__text {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  text-align: center;
}

/* 分割线 */
.menu-divider {
  height: 1rpx;
  background-color: var(--color-bg-secondary);
  margin: 0 var(--spacing-lg);
}

/* 退出登录行 */
/* 从图5提取：左对齐，图标+文字，padding:32rpx */
.logout-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-sm);
  padding: 36rpx var(--spacing-lg);
}

.logout-icon {
  font-size: 36rpx;
  color: var(--color-primary);
}

.logout-text {
  font-size: var(--font-size-base);
  color: var(--color-primary);
}

/* ===== 底部文字 ===== */
/* 从图5提取：22rpx，#CCCCCC，居中，带小图标 */
.footer {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}

.footer__text {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

/* ===== 加载状态 ===== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-bg-secondary);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }
