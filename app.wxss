* {
  box-sizing: border-box;
}

/* 清除默认边距 */
view, text, image, input, button {
  margin: 0;
  padding: 0;
}

/* 按钮重置 */
button {
  background: transparent;
  border: none;
  padding: 0;
  line-height: 1;
}

button::after {
  border: none;
}

/* 图片占位符通用样式 */
.img-placeholder {
  background-color: #F0F0F0;
  border: 1rpx dashed #CCCCCC;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999999;
  font-size: 22rpx;
  text-align: center;
  overflow: hidden;
}
