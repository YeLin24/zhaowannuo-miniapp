/* 全局样式重置 */
page {
  font-family: var(--font-family);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  background-color: var(--color-bg);
  box-sizing: border-box;
}

/* 清除默认边距 */
view, text, image, input, button {
  margin: 0;
  padding: 0;
}

/* 按钮重置 */
button {
  background: transparent;
  border: none;
  padding: 0;
  line-height: 1;
}

button::after {
  border: none;
}

/* ===== CSS Variables ===== */
:root {
  /* 颜色系统 */
  --color-primary: #000000;
  --color-bg: #FFFFFF;
  --color-bg-secondary: #F5F5F5;
  --color-text-primary: #000000;
  --color-text-secondary: #999999;
  --color-text-muted: #CCCCCC;
  --color-border: #EEEEEE;
  --color-accent-orange: #FF8C00;
  --color-vip-bg: #FFF0E0;
  --color-vip-text: #FF7B30;
  --color-tag-border: #000000;
  --color-red: #E53E3E;
  --color-dark-bg: #000000;

  /* 字体系统 */
  --font-family: -apple-system, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-lg: 36rpx;
  --font-size-xl: 44rpx;
  --font-weight-regular: 400;
  --font-weight-bold: 600;

  /* 间距系统 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 40rpx;

  /* 圆角系统 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 50%;
  --radius-pill: 40rpx;
}

/* 图片占位符通用样式 */
.img-placeholder {
  background-color: #F0F0F0;
  border: 1rpx dashed #CCCCCC;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999999;
  font-size: 22rpx;
  text-align: center;
  overflow: hidden;
}
